theme = dark:Kanso Zen,light:Kanso Pearl

font-family = "SauceCodePro Nerd Font Mono"
font-family-bold = "SauceCodePro Nerd Font Mono"
font-family-italic = "SauceCodePro Nerd Font Mono"
font-family-bold-italic = "SauceCodePro Nerd Font Mono"
font-size = 16

maximize = true
window-padding-x = 0
window-padding-y = 0

cursor-style = bar
cursor-style-blink = true
mouse-hide-while-typing = true
copy-on-select = clipboard

background-opacity = 1
background-blur = true

macos-option-as-alt = true
macos-titlebar-style = transparent
window-colorspace = display-p3

quick-terminal-position = center

keybind = global:cmd+backquote=toggle_quick_terminal
keybind = global:cmd+p=toggle_quick_terminal
keybind = cmd+r=reload_config
